{
  "id": "system",
  "title": "System",
  "description": "The meta-layer where ARC manages itself \u2014 contexts, types, fields, agents, and configuration.",
  "application": {
    "routes": {
      "public": null,
      "admin": "/dashboard/system"
    },
    "nav": {
      "label": "System",
      "icon": "Settings",
      "group": "system"
    },
    "entryTypes": [
      "agents",
      "roles",
      "access",
      "environments",
      "extensions",
      "providers",
      "forms",
      "lab",
      "docs"
    ],
    "defaultView": null,
    "features": {
      "publicSite": false,
      "rss": false,
      "search": false
    }
  },
  "presentation": {
    "theme": "system",
    "layout": "admin",
    "palette": {
      "primary": "#1a1a1a",
      "accent": "#6366f1",
      "background": "#f8f8f8",
      "surface": "#ffffff",
      "text": "#1a1a1a",
      "textMuted": "#666666"
    },
    "typography": {
      "heading": "Inter",
      "body": "Inter"
    },
    "density": "compact"
  },
  "structure": {
    "primaryType": "agents",
    "types": [
      {
        "id": "agent",
        "schema": "./types/agent.yaml",
        "listView": "list",
        "sortDefault": "handle-asc"
      },
      {
        "id": "role",
        "schema": "./types/role.yaml",
        "listView": "list",
        "sortDefault": "id-asc"
      },
      {
        "id": "access",
        "schema": "./types/access.yaml",
        "listView": "list",
        "sortDefault": "agentHandle-asc"
      }
    ]
  },
  "data": {
    "provider": "github",
    "owner": "bldrs",
    "repo": "arc-data",
    "branch": "main",
    "path": "contexts/system/data",
    "localFallback": {
      "provider": "local",
      "source": "system-data",
      "note": "Non-agent system data (environments, providers, extensions, forms) is stored locally in the browser until GitHub sync is extended to cover it.\n"
    }
  }
}